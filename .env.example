# Токен control-бота (получить у @BotFather)
BOT_TOKEN=

# Telegram user_id владельца (узнать у @userinfobot). Только этому юзеру разрешено пользоваться ботом.
OWNER_TELEGRAM_ID=

# Ключ шифрования для сессий и API-токенов (Fernet, base64).
# Сгенерировать: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# Путь к БД (по умолчанию data/app.db, в Docker — /app/data/app.db)
DATABASE_URL=sqlite+aiosqlite:///data/app.db

# Прокси для Telegram API (socks5://ip:port или http://ip:port). Оставьте пустым, если VPN системный.
PROXY_URL=

# Отключить локальную транскрипцию faster-whisper (true — для VDS с малым RAM/Railway)
DISABLE_LOCAL_TRANSCRIPTION=false

# --- Имена LLM-моделей (переопределяются через .env, см. src/config.py) ---
OPENAI_CHAT_LIGHT_MODEL=gpt-5-mini
OPENAI_CHAT_HEAVY_MODEL=gpt-5.5
OPENAI_EMBED_MODEL=text-embedding-3-small

GEMINI_CHAT_LIGHT_MODEL=gemini-3-flash
GEMINI_CHAT_HEAVY_MODEL=gemini-3.1-pro
GEMINI_EMBED_MODEL=text-embedding-004

MISTRAL_CHAT_LIGHT_MODEL=mistral-small-latest
MISTRAL_CHAT_HEAVY_MODEL=magistral-medium-latest
MISTRAL_EMBED_MODEL=mistral-embed
MISTRAL_STT_MODEL=voxtral-mini-transcribe-latest
